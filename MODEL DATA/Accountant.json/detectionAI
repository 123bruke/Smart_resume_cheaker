    "classification_rules": {
        "ai_indicators": {
            "linguistic": [
                "excessive_use_of_strong_adjectives",
                "repetitive_sentence_structures",
                "lack_of_specific_dates",
                "generic_job_descriptions",
                "overuse_of_buzzwords",
                "perfect_grammar_with_no_variation",
                "missing_typos_or_imperfections",
                "consistent_verb_tense_without_flow",
                "lack_of_personal_pronouns",
                "formulaic_achievement_statements"
            ],
            "structural": [
                "perfectly_aligned_formatting",
                "identical_section_lengths",
                "predictable_bullet_point_patterns",
                "no_variation_in_resume_length",
                "standard_template_structure",
                "missing_whitespace_anomalies",
                "consistent_font_usage",
                "no_marginal_notes_or_comments"
            ],
            "content": [
                "vague_metric_improvements",
                "missing_company_names",
                "generic_project_descriptions",
                "no_career_progression_gaps",
                "perfect_job_hop_timeline",
                "overemphasis_on_soft_skills",
                "missing_contextual_details",
                "standardized_skill_lists"
            ]
        },
        "human_indicators": {
            "linguistic": [
                "varied_sentence_lengths",
                "inconsistent_verb_tense",
                "presence_of_minor_typos",
                "use_of_colloquial_language",
                "personal_anecdotes",
                "emotional_language",
                "varied_punctuation",
                "abbreviations_and_shortcuts",
                "hedging_language",
                "unique_phrasing"
            ],
            "structural": [
                "inconsistent_spacing",
                "varied_bullet_point_lengths",
                "unique_section_order",
                "presence_of_handwritten_notes",
                "inconsistent_date_formats",
                "custom_section_headings",
                "uneven_margins",
                "mixed_font_sizes"
            ],
            "content": [
                "specific_project_details",
                "realistic_career_gaps",
                "unique_software_experience",
                "industry_specific_jargon",
                "detailed_process_descriptions",
                "mention_of_challenges_faced",
                "team_collaboration_details",
                "progressive_responsibilities",
                "specific_financial_systems"
            ]
        }
    },
